# Helpers

```{r helpers}
.read_csv <- function(path) {
  data.table::fread(path, data.table = FALSE, na.strings = c("", "NA"))
}

# FIX (was): get_name() stripped from the FIRST underscore, collapsing all
# replicates of a genotype but also destroying any genotype name that contained
# an underscore in a meaningful position. Now strips only the final _digit suffix
# (the replicate number), so APF-665T_3_19_B_1 → APF-665T_3_19_B, which is the
# unique plant ID, and grouping by NAME correctly aggregates plant replicates.
get_name <- function(x) sub("_\\d+$", "", x)

.clamp_counts <- function(v, maxv) {
  v <- suppressWarnings(as.numeric(v))
  v <- pmax(0, v, na.rm = FALSE)
  v <- pmin(v, maxv)
  v
}

save_png_hq <- function(plot, filename, width = 12, height = 8, dpi = 600) {
  ggplot2::ggsave(filename, plot,
                  width = width, height = height,
                  dpi = dpi, units = "in", type = "cairo-png")
}
