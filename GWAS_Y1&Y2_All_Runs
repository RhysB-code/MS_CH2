# Helper Functions

```{r helpers}
# ── CSV reader ────────────────────────────────────────────────────────────────
# Treats blank cells and common "no data" strings as NA.
# "no cuttings" entries from Y2 missing-rep notation are also treated as NA.
.read_csv <- function(path) {
  data.table::fread(path, data.table=FALSE,
                    na.strings=c("","NA","na","no cuttings","No cuttings","N/A"))
}

# ── Y1 name extraction ────────────────────────────────────────────────────────
# Y1 lug ID format: GENOTYPE_fieldrow_fieldcol_BLOCK_rep
# Examples:
#   A-2520T_7_7_C_1   →  genotype = A-2520T,  block = C
#   Osage_1_A_1       →  genotype = Osage,     block = A
# Strategy: strip final _digit (rep), then strip trailing field coordinates.
get_name_y1 <- function(x) {
  x <- stringr::str_trim(x)
  x <- sub("_\\d+$", "", x)                          # remove rep suffix
  x <- sub("_\\d+_\\d+_[A-Da-d]$", "", x)            # remove _row_col_block
  x <- sub("_\\d+_[A-Da-d]$", "", x)                 # remove _col_block
  x <- sub("_[A-Da-d]$", "", x)                      # remove _block alone
  x
}
get_block_y1 <- function(x) {
  toupper(stringr::str_extract(x, "[A-Da-d](?=_\\d+$)"))
}

# ── Y2 name extraction ────────────────────────────────────────────────────────
# Y2 tag format: SITEPREFIX_GENOTYPE_LrowBLOCK_Pposition
# Examples:
#   ANG_A-2958T_L1A_P1     →  genotype = A-2958T,  block = A
#   WSH_APF-731TN_L1A_P8   →  genotype = APF-731TN, block = A
#   Osage_L1A_P0           →  genotype = Osage,     block = A
#   ANG_NC430 (Von)_L1A_P4 →  alias stripped → NC430, block = A
get_name_y2 <- function(x) {
  x <- stringr::str_trim(x)
  x <- sub("^(ANG|NOV|WSH|BEN|BSH)_+", "", x)        # strip site prefix
  x <- sub("_+L\\d+[A-Da-d]_+P[\\d.]+$", "", x)      # strip field coords
  x <- sub("\\s*\\([^)]*\\)", "", x)                  # strip aliases e.g. (Von)
  x <- stringr::str_trim(x)
  x <- sub("[_ ]+$", "", x)                           # trailing punctuation
  x
}
get_block_y2 <- function(x) {
  toupper(stringr::str_extract(x, "(?<=L\\d)[A-Da-d](?=_+P)"))
}

# ── Count clamping ────────────────────────────────────────────────────────────
# Converts to numeric and enforces 0 ≤ count ≤ total_buds.
# Guards against data entry errors.
.clamp <- function(v, maxv) {
  v    <- suppressWarnings(as.numeric(v))
  maxv <- suppressWarnings(as.numeric(maxv))
  pmin(pmax(v, 0, na.rm=FALSE), maxv, na.rm=FALSE)
}

# ── High-quality PNG saver ────────────────────────────────────────────────────
# 600 DPI with Cairo renderer for clean anti-aliased text in publication plots.
save_png_hq <- function(p, filename, w=14, h=8, dpi=600) {
  ggplot2::ggsave(filename, p, width=w, height=h, dpi=dpi,
                  units="in", type="cairo-png")
}
```

