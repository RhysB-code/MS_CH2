# ── run_missing_manhattan_plots() ─────────────────────────────────────────────
# Scans the output folder, identifies runs whose PNG does not yet exist,
# and runs only those. Safe to call at any time — completed runs are skipped.

run_missing_manhattan_plots <- function() {

  status <- run_config %>%
    dplyr::rowwise() %>%
    dplyr::mutate(
      png_path = file.path(
        mp_outdir,
        paste0(sprintf("%03d", run_id), "__", Block, "__", Dataset,
               "__", Cohort, "__", Trait, ".png")
      ),
      exists = file.exists(png_path)
    ) %>%
    dplyr::ungroup()

  done    <- dplyr::filter(status,  exists)
  missing <- dplyr::filter(status, !exists)

  cat("[STATUS]", nrow(done), "runs complete |", nrow(missing), "runs missing\n\n")

  if (nrow(missing)==0) {
    message("[OK] All 100 Manhattan plots already exist."); return(invisible(NULL))
  }

  cat("Missing runs:\n")
  print(missing %>% dplyr::select(run_id, Block, Cohort, Dataset, Trait))

  for (i in missing$run_id) {
    message("\n[RUNNING] Run ", sprintf("%03d", i))
    run_gwas_single(i)
  }

  message("\n[COMPLETE] All missing plots generated.")
}

# ── Call it ───────────────────────────────────────────────────────────────────
run_missing_manhattan_plots()
