## PF Status Assignment

```{r pf-assignment}
# ── PF classification rules ───────────────────────────────────────────────────
# APF prefix  → PF=1 (primocane-fruiting breeding lines)
# A- prefix   → PF=0 (floricane-fruiting breeding lines)
# NC430       → PF=0 (selection number for the variety Von, confirmed FF)
# Named varieties assigned individually based on known biology.
# Anything unclassified prints a warning so it can be added manually.

all_names <- union(unique(y1_long$NAME), unique(y2_long$NAME))

PF_tbl <- tibble::tibble(NAME = all_names) %>%
  dplyr::mutate(
    PF = dplyr::case_when(
      startsWith(NAME, "APF")   ~ 1L,
      startsWith(NAME, "A-")    ~ 0L,
      NAME == "NC430"           ~ 0L,   # selection number for Von (FF)
      NAME %in% c("PrimeArkFreedom","PrimeArkHorizon","Superlicious") ~ 1L,
      NAME %in% c("Osage","Ouachita","Natchez","Apache","Ponca","Caddo",
                  "Navaho","Lochness","Immaculate","Von","Tupy","Stella",
                  "Thunderhead","Celestial","Twilight") ~ 0L,
      TRUE ~ NA_integer_
    )
  )

cat("[PF] PF=1:", sum(PF_tbl$PF==1, na.rm=TRUE),
    "| PF=0:", sum(PF_tbl$PF==0, na.rm=TRUE),
    "| PF=NA (unclassified):", sum(is.na(PF_tbl$PF)), "\n")

unclass <- dplyr::filter(PF_tbl, is.na(PF))$NAME
if (length(unclass) > 0) {
  warning("[PF] Unclassified genotypes — add to case_when above: ",
          paste(unclass, collapse=", "))
}
```

## BLUE Estimation (Per-Year & Combined)

<div class="stat-box">
**BLUE model: `PERCENT ~ Block + Timepoint + NAME`**

Block captures spatial field variation (blocks A–D within each trial).
Timepoint captures the systematic increase in budbreak across assessment dates —
not a biological genotype effect, just the progression of the season.
The NAME coefficient is the BLUE for each genotype: the estimated mean budbreak
percentage after accounting for both sources of non-genetic variation, with no
shrinkage toward the population mean.

For the combined-year model, `Year` is added as an additional fixed effect to
absorb the mean difference between the 2024–25 and 2025–26 seasons before
estimating genotypic effects.
</div>

```{r blue-models}
# ── BLUE helper: fits the fixed-effects model and extracts NAME coefficients ──
compute_blue <- function(df_wide, label) {
  long <- df_wide %>%
    dplyr::select(NAME, Block, PERCENT_T1, PERCENT_T2) %>%
    tidyr::pivot_longer(c(PERCENT_T1, PERCENT_T2),
                        names_to="Timepoint", values_to="PERCENT") %>%
    dplyr::filter(!is.na(PERCENT), is.finite(PERCENT)) %>%
    dplyr::mutate(NAME=factor(NAME), Block=factor(Block), Timepoint=factor(Timepoint))

  cat("[BLUE", label, "] obs:", nrow(long),
      "| genotypes:", n_distinct(long$NAME), "\n")

  mod <- tryCatch(
    lm(PERCENT ~ Block + Timepoint + NAME, data=long),
    error=function(e) {
      message("[BLUE", label, " FALLBACK] Using means. ", conditionMessage(e))
      NULL
    }
  )

  if (!is.null(mod)) {
    co  <- coef(mod)
    val <- co[grepl("^NAME", names(co))]
    tibble::tibble(NAME=gsub("^NAME","",names(val)), BLUE_PERCENT=as.numeric(val))
  } else {
    long %>% dplyr::group_by(NAME) %>%
      dplyr::summarise(BLUE_PERCENT=mean(PERCENT, na.rm=TRUE), .groups="drop")
  }
}

blue_y1 <- compute_blue(y1_long, "Y1")
blue_y2 <- compute_blue(y2_long, "Y2")

# ── Combined-year BLUE ────────────────────────────────────────────────────────
# Year added as fixed effect. This absorbs systematic season differences
# (e.g. one year having higher overall budbreak) before estimating genotype means.
comb_long <- dplyr::bind_rows(
    y1_long %>% dplyr::select(NAME, Block, PERCENT_T1, PERCENT_T2, Year),
    y2_long %>% dplyr::select(NAME, Block, PERCENT_T1, PERCENT_T2, Year)
  ) %>%
  tidyr::pivot_longer(c(PERCENT_T1, PERCENT_T2),
                      names_to="Timepoint", values_to="PERCENT") %>%
  dplyr::filter(!is.na(PERCENT), is.finite(PERCENT)) %>%
  dplyr::mutate(NAME=factor(NAME), Block=factor(Block),
                Year=factor(Year),  Timepoint=factor(Timepoint))

cat("[BLUE Combined] obs:", nrow(comb_long),
    "| genotypes:", n_distinct(comb_long$NAME), "\n")

mod_comb <- tryCatch(
  lm(PERCENT ~ Year + Block + Timepoint + NAME, data=comb_long),
  error=function(e) { message("[BLUE Combined FAIL] ", conditionMessage(e)); NULL }
)

if (!is.null(mod_comb)) {
  co  <- coef(mod_comb)
  val <- co[grepl("^NAME", names(co))]
  blue_comb <- tibble::tibble(NAME=gsub("^NAME","",names(val)),
                               BLUE_PERCENT=as.numeric(val))
} else {
  blue_comb <- comb_long %>% dplyr::group_by(NAME) %>%
    dplyr::summarise(BLUE_PERCENT=mean(PERCENT, na.rm=TRUE), .groups="drop")
}
cat("[BLUE Combined] genotypes with estimate:", nrow(blue_comb), "\n")
```

## Composite Traits & Phenotypic PCA

```{r pca-traits}
# ── PCA helper ────────────────────────────────────────────────────────────────
# Computes per-genotype means, COMP_PERCENT, and PC1/PC2 from a long table.
# PC1 typically captures overall chilling responsiveness (high PERCENT at both
# timepoints). PC2 typically captures the early-vs-late contrast (high T1 but
# low T2 relative to others, or vice versa) — i.e. timing of budbreak onset.
make_trait_table <- function(df_long, label) {
  means <- df_long %>%
    dplyr::group_by(NAME) %>%
    dplyr::summarise(
      across(c(BIN_T1, BIN_T2, PERCENT_T1, PERCENT_T2),
             \(x) mean(x, na.rm=TRUE)),
      .groups="drop"
    ) %>%
    dplyr::mutate(
      COMP_PERCENT = rowMeans(cbind(PERCENT_T1, PERCENT_T2), na.rm=TRUE)
    )

  pca_in <- means %>%
    dplyr::filter(complete.cases(dplyr::select(., PERCENT_T1, PERCENT_T2)))

  pca_mat <- scale(pca_in %>% dplyr::select(PERCENT_T1, PERCENT_T2))
  pca_res <- prcomp(pca_mat, center=FALSE, scale.=FALSE)
  var_exp <- summary(pca_res)$importance["Proportion of Variance",]
  cat("[PCA", label, "] PC1:", round(var_exp[1]*100,1),
      "% | PC2:", round(var_exp[2]*100,1), "%\n")

  scores <- tibble::tibble(NAME=pca_in$NAME,
                           PC1=pca_res$x[,1],
                           PC2=pca_res$x[,2])
  dplyr::left_join(means, scores, by="NAME")
}

traits_y1   <- make_trait_table(y1_long,                         "Y1")
traits_y2   <- make_trait_table(y2_long,                         "Y2")
traits_comb <- make_trait_table(dplyr::bind_rows(y1_long,y2_long),"Combined")
