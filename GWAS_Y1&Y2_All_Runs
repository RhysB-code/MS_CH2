# GWAS Engine

```{r gwas-function}
# ── run_gwas_single() ─────────────────────────────────────────────────────────
# Runs one complete GWAS analysis:
#   1. Pulls cohort + trait from run_config
#   2. Safety checks (trait exists, n ≥ 20)
#   3. Writes a per-run phenotype CSV for GWASpoly
#   4. read.GWASpoly() — loads pheno + geno, ploidy=4, dosage format
#   5. set.K() with LOCO=TRUE — kinship matrix excluding the focal chromosome
#      (prevents the causal chromosome from suppressing its own signal)
#   6. GWASpoly() — tests additive, 1-dom, 2-dom, general models at every marker
#   7. set.threshold() — M.eff multiple-testing correction at α=0.05
#   8. Saves score table, QTL table, and Manhattan plot PNG
#
# force=FALSE: skips the run if its PNG already exists (default — safe to call)
# force=TRUE:  regenerates even if PNG exists

run_gwas_single <- function(run_id, force=FALSE) {

  cfg <- dplyr::filter(run_config, run_id == !!run_id)
  if (nrow(cfg)==0) { message("[SKIP] Run ", run_id, " not in config."); return(invisible(NULL)) }

  trait <- cfg$Trait
  cov   <- cfg$Covariate

  png_path <- file.path(mp_outdir,
    paste0(sprintf("%03d", run_id), "__", cfg$Block, "__", cfg$Dataset,
           "__", cfg$Cohort, "__", trait, ".png"))

  if (file.exists(png_path) && !force) {
    message("[SKIP] Run ", sprintf("%03d", run_id), " PNG exists. Pass force=TRUE to rerun.")
    return(invisible(NULL))
  }

  df <- get_cohort_df(cfg$Dataset, cfg$Cohort)

  if (!trait %in% names(df)) {
    message("[SKIP] Trait '", trait, "' missing from master table. Run ", run_id)
    return(invisible(NULL))
  }

  n_obs <- sum(!is.na(df[[trait]]))
  if (n_obs < 20) {
    message("[SKIP] Only ", n_obs, " obs for '", trait, "' in run ", run_id, " — too few.")
    return(invisible(NULL))
  }

  # Write per-run phenotype CSV
  df_use <- if (cov=="PF") {
    df %>% dplyr::select(NAME, dplyr::all_of(trait), PF) %>%
      dplyr::filter(!is.na(.data[[trait]]))
  } else {
    df %>% dplyr::select(NAME, dplyr::all_of(trait)) %>%
      dplyr::filter(!is.na(.data[[trait]]))
  }

  pheno_out <- file.path(out_dir, paste0("pheno_run", sprintf("%03d", run_id), ".csv"))
  data.table::fwrite(df_use, pheno_out)

  # GWASpoly pipeline
  data_gp <- GWASpoly::read.GWASpoly(
    ploidy=4, pheno.file=pheno_out, geno.file=geno_out,
    format="numeric", n.traits=ncol(df_use)-1
  )

  data_gp <- GWASpoly::set.K(data_gp, LOCO=TRUE)

  params <- if (cov=="PF") {
    GWASpoly::set.params(fixed="PF", fixed.type="factor")
  } else {
    GWASpoly::set.params()
  }

  fit <- GWASpoly::GWASpoly(
    data=data_gp, traits=trait,
    models=c("additive","1-dom","2-dom","general"),
    params=params,
    n.core=max(1L, parallel::detectCores()-1L)
  )

  thr <- GWASpoly::set.threshold(fit, method="M.eff", level=0.05)

  # Save score table and QTL peaks
  base <- file.path(out_dir,
    paste0("run", sprintf("%03d", run_id), "_", cfg$Block, "_", trait))
  GWASpoly::write.GWASpoly(thr, trait=trait,
    filename=paste0(base, "_scores.csv"), what="scores")
  qtl <- GWASpoly::get.QTL(thr, traits=trait, models="additive", bp.window=5e6)
  data.table::fwrite(qtl, paste0(base, "_QTL.csv"))

  # Save Manhattan plot
  p <- GWASpoly::manhattan.plot(thr, traits=trait) +
    ggplot2::ggtitle(
      label    = paste0("Run ", sprintf("%03d", run_id),
                        " | Block ", cfg$Block,
                        " | ", cfg$Dataset, " | Cohort: ", cfg$Cohort,
                        " | Trait: ", trait),
      subtitle = paste0(cfg$Transformation,
                        if (cov!="None") paste0(" | Covariate: ", cov) else "")
    ) +
    ggplot2::theme(plot.title    = ggplot2::element_text(size=13, face="bold"),
                   plot.subtitle = ggplot2::element_text(size=11, color="grey40"))

  save_png_hq(p, png_path)
  message("[DONE] Run ", sprintf("%03d", run_id),
          " | Block ", cfg$Block, " | ", cfg$Dataset, " | ", trait,
          "\n  →  ", png_path)
}
